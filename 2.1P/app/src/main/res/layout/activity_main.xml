<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/currency"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Spinner
        android:id="@+id/spinInputCurrency"
        android:layout_width="wrap_content"
        android:layout_height="50sp"
        android:entries="@array/currencies"
        android:layout_marginEnd="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/etInput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/etInput"
        app:layout_constraintTop_toTopOf="@id/etInput" />

    <TextView
        android:id="@+id/tvConvertWord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20sp"
        android:layout_marginEnd="40sp"
        android:text="@string/convertSymbol"
        android:textSize="40sp"
        android:textStyle="bold"
        android:translationY="-6sp"
        app:layout_constraintBottom_toTopOf="@id/spinOutputCurrency"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/divider"
        app:layout_constraintTop_toBottomOf="@id/spinInputCurrency" />

    <Spinner
        android:id="@+id/spinOutputCurrency"
        android:layout_width="wrap_content"
        android:layout_height="50sp"
        android:entries="@array/currencies"
        android:layout_marginEnd="20sp"
        app:layout_constraintBottom_toBottomOf="@id/etOutput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/etOutput"
        app:layout_constraintTop_toTopOf="@id/etOutput" />

    <TextView
        android:id="@+id/tvInputPrefix"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="5sp"
        android:textSize="45sp"
        android:alpha="0.5"
        app:layout_constraintBottom_toBottomOf="@+id/etInput"
        app:layout_constraintEnd_toStartOf="@+id/etInput"
        app:layout_constraintTop_toTopOf="@+id/etInput" />

    <EditText
        android:id="@+id/etInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/currInputHint"
        android:background="@null"
        android:inputType="numberDecimal"
        android:textSize="45sp"
        android:layout_marginStart="50sp"
        android:layout_marginEnd="10sp"
        android:layout_marginBottom="20sp"
        app:layout_constraintBottom_toTopOf="@id/divider"
        app:layout_constraintEnd_toStartOf="@id/spinInputCurrency"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvOutputPrefix"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0.5"
        android:layout_marginEnd="5sp"
        android:textSize="45sp"
        app:layout_constraintBottom_toBottomOf="@+id/etOutput"
        app:layout_constraintEnd_toStartOf="@+id/etOutput"
        app:layout_constraintTop_toTopOf="@+id/etOutput" />

    <EditText
        android:id="@+id/etOutput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/currInputHint"
        android:inputType="numberDecimal"
        android:background="@null"
        android:textSize="45sp"
        android:layout_marginStart="50sp"
        android:layout_marginEnd="10sp"
        android:layout_marginTop="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/spinOutputCurrency"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/divider"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintVertical_chainStyle="packed" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tabItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Currency" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fuel" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Temperature" />

    </com.google.android.material.tabs.TabLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1sp"
        android:background="?android:attr/listDivider"
        android:layout_marginStart="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/etOutput"
        app:layout_constraintEnd_toStartOf="@id/tvConvertWord"
        app:layout_constraintTop_toBottomOf="@id/etInput" />

    <Button
        android:id="@+id/btnClear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Clear"
        app:layout_constraintVertical_bias="0.25"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/etOutput" />


</androidx.constraintlayout.widget.ConstraintLayout>